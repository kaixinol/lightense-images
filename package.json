{
  "name": "@kaesinol/lightense-images",
  "version": "2.0.3",
  "description": "A dependency-free pure JavaScript image zooming library less than 4 KB (gzipped)",
  "main": "dist/lightense.js",
  "scripts": {
    "build": "vite build",
    "test": "pnpm exec eslint src/index.js",
    "watch": "vite build --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaixinol/lightense-images.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "keywords": [
    "css",
    "image",
    "javascript",
    "vite"
  ],
  "author": "Tunghsiao Liu",
  "contributors": [
    "kaesinol"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/kaixinol/lightense-images/issues"
  },
  "homepage": "https://github.com/kaixinol/lightense-images",
  "browserslist": [
    "not dead",
    "since 2020"
  ],
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "eslint": "^10.0.2",
    "vite": "^7.1.0"
  },
  "release-it": {
    "hooks": {
      "before:bump": [
        "pnpm test"
      ],
      "after:bump": [
        "pnpm build"
      ]
    },
    "github": {
      "release": true
    }
  },
  "packageManager": "pnpm@10.28.2",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/lightense.js",
      "require": "./dist/lightense.js"
    }
  }
}